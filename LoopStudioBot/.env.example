# Telegram Bot Token (lấy từ @BotFather)
BOT_TOKEN=your_bot_token_here

# Chat ID nhận báo cáo định kỳ (dùng @userinfobot để lấy)
REPORT_CHAT_ID=your_chat_id_here

# Khoảng thời gian chạy netstat tự động (giây) - mặc định 7200 = 2 giờ
NETSTAT_INTERVAL_SECONDS=7200

# Timezone cho scheduler
TIMEZONE=Asia/Ho_Chi_Minh
